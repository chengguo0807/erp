# EnterpriseHub ERP 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# JWT配置（生产环境必须使用强随机密钥）
# 生成命令: openssl rand -base64 64
JWT_SECRET=your-strong-jwt-secret-key-here-at-least-256-bits
JWT_EXPIRATION=7200

# MySQL配置
MYSQL_ROOT_PASSWORD=your-strong-mysql-password-here

# Redis配置
REDIS_PASSWORD=your-strong-redis-password-here

# 注意事项：
# 1. 不要将 .env 文件提交到Git仓库
# 2. 密码至少16位，包含大小写字母、数字、特殊字符
# 3. 每个环境使用不同的密钥和密码
# 4. 定期更换密码
